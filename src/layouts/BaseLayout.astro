---
import Favicon from '../../public/apple-touch-icon.png';

import Head from '../components/Head.astro';
import Footer from '../components/Footer.astro';
import Cursor from '../components/Cursor.astro';
import Background from '../components/Background.astro';
---

<!doctype html>
<html lang="en">
  <Head title="btjawa's Home" description="btjawa's home page." image={Favicon} />
	<body>
    <Cursor />
    <Background />
		<main id="main">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/cursor.ts"></script>
    <script src="../scripts/background.ts"></script>
	</body>
</html>

<style>
main {
  display: flex;
  flex-direction: column;
  flex: 1;
  align-items: center;
  height: 100%;
  width: 100%;
}
</style>
